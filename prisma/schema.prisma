// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]
}

model Job {
  id          String   @id @default(cuid()) @unique()
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  // the job type field is not added since queues are respective to job types
  // say the queues are created wrt priority like default, high / low processing
  // then there might be a need for job types
  data        Json
  status      JobStatus @default(PENDING)
  delayUntil  DateTime?
  bullJobId   String?
  queueName   QueueType

  attempts    Int       @default(0)
  maxAttempts Int       @default(5)

  createdAt   DateTime  @default(now())

  result      Json?
  error       String?

  @@index([status])
  @@index([queueName])
  @@index([userId])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum QueueType {
  EMAIL
  IMAGE_PROCESSING
  REPORT_GENERATION
  SCRAPING
}